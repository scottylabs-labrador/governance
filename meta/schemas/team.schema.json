{
  "type": "object",
  "required": [
    "name",
    "description",
    "repos",
    "membership"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Public or display name of the team (e.g. used in GitHub org team names)."
    },
    "description": {
      "type": "string",
      "description": "A brief description of the team."
    },
    "website": {
      "type": "string",
      "format": "url",
      "description": "Website URL associated with the team."
    },
    "server": {
      "type": "string",
      "format": "url",
      "description": "Server URL associated with the team."
    },
    "create-oidc-clients": {
      "type": "boolean",
      "description": "Whether to create OIDC clients for the team.",
      "default": true
    },
    "repos": {
      "type": "array",
      "description": "The GitHub repositories owned by the team.",
      "items": {
        "$ref": "#/definitions/repo"
      }
    },
    "membership": {
      "type": "array",
      "description": "List of membership records by timeframe.",
      "items": {
        "type": "object",
        "required": [
          "timeframe",
          "leads",
          "members"
        ],
        "properties": {
          "timeframe": {
            "type": "string",
            "description": "Membership timeframe (e.g. '2025-2026' or Fall 2025)."
          },
          "leads": {
            "type": "array",
            "description": "GitHub usernames of the leads for this timeframe.",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "members": {
            "type": "array",
            "description": "Members for this timeframe.",
            "items": {
              "$ref": "#/definitions/member"
            },
            "minItems": 1,
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      },
      "minProperties": 1
    },
    "additionalProperties": false
  },
  "additionalProperties": false,
  "allOf": [
    {
      "$comment": "Require 'website' and 'server' when 'create-oidc-clients' is missing or true.",
      "if": {
        "anyOf": [
          {
            "not": {
              "required": [
                "create-oidc-clients"
              ]
            }
          },
          {
            "properties": {
              "create-oidc-clients": {
                "const": true
              }
            }
          }
        ]
      },
      "then": {
        "required": [
          "website",
          "server"
        ]
      }
    }
  ],
  "definitions": {
    "repo": {
      "type": "object",
      "description": "A repository owned by the team.",
      "required": [
        "name",
        "description"
      ],
      "properties": {
        "name": {
          "description": "GitHub repository name (e.g. 'goldador').",
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.-]+$"
        },
        "description": {
          "description": "Brief description of the repository.",
          "type": "string"
        }
      },
      "additionalProperties": false
    },
    "member": {
      "type": "object",
      "description": "A member of the team, used in the 'members' array.",
      "required": [
        "github-username"
      ],
      "properties": {
        "github-username": {
          "type": "string",
          "description": "GitHub username of the member."
        },
        "title": {
          "type": "string",
          "description": "Title of the member in the team."
        }
      },
      "additionalProperties": false
    }
  }
}
