{
  "type": "object",
  "required": [
    "name",
    "description",
    "repos",
    "membership"
  ],
  "properties": {
    "name": {
      "type": "string",
      "description": "Public or display name of the team (e.g. used in GitHub org team names)."
    },
    "website": {
      "type": "string",
      "format": "url",
      "description": "Deployed URL associated with the team."
    },
    "description": {
      "type": "string",
      "description": "A brief description of the team."
    },
    "create-oidc-clients": {
      "type": "boolean",
      "description": "Whether to create OIDC clients for the team.",
      "default": true
    },
    "repos": {
      "type": "array",
      "description": "The GitHub repositories owned by the team.",
      "items": {
        "$ref": "#/definitions/repo"
      },
      "uniqueItems": true
    },
    "membership": {
      "type": "array",
      "description": "List of membership records by timeframe.",
      "items": {
        "type": "object",
        "required": [
          "timeframe",
          "maintainers",
          "contributors"
        ],
        "properties": {
          "timeframe": {
            "type": "string",
            "description": "Membership timeframe (e.g. '2025-2026' or Fall 2025)."
          },
          "maintainers": {
            "type": "array",
            "description": "GitHub usernames of the maintainers for this timeframe.",
            "items": {
              "type": "string"
            },
            "minItems": 1,
            "uniqueItems": true
          },
          "contributors": {
            "type": "array",
            "description": "Contributors for this timeframe.",
            "items": {
              "$ref": "#/definitions/member"
            },
            "minItems": 1,
            "uniqueItems": true
          }
        },
        "additionalProperties": false
      },
      "minProperties": 1
    },
    "additionalProperties": false
  },
  "additionalProperties": false,
  "allOf": [
    {
      "$comment": "Require 'website' when 'create-oidc-clients' is missing or true.",
      "if": {
        "anyOf": [
          {
            "not": {
              "required": [
                "create-oidc-clients"
              ]
            }
          },
          {
            "properties": {
              "create-oidc-clients": {
                "const": true
              }
            }
          }
        ]
      },
      "then": {
        "required": [
          "website"
        ]
      }
    }
  ],
  "definitions": {
    "member": {
      "type": "object",
      "description": "A member of the team, used in the 'contributors' array.",
      "required": [
        "github-username",
        "title"
      ],
      "properties": {
        "github-username": {
          "type": "string",
          "description": "GitHub username of the contributor."
        },
        "title": {
          "type": "string",
          "description": "Title of the contributor in the team."
        }
      },
      "additionalProperties": false
    },
    "repo": {
      "type": "object",
      "description": "A repository owned by the team.",
      "required": [
        "slug",
        "description"
      ],
      "properties": {
        "slug": {
          "description": "GitHub repository slug (e.g. 'governance').",
          "type": "string",
          "pattern": "^[a-zA-Z0-9_.-]+$"
        },
        "description": {
          "description": "Brief description of the repository.",
          "type": "string"
        }
      },
      "additionalProperties": false
    }
  }
}
